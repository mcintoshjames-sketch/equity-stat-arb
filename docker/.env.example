# Copy to docker/.env and fill in real values.
# docker/.env is git-ignored.

SCHWAB_APP_KEY=YOUR_APP_KEY_HERE
SCHWAB_APP_SECRET=YOUR_APP_SECRET_HERE

# FMP earnings calendar API (optional — enables earnings blackout)
# Get a free key at https://financialmodelingprep.com/developer/docs/
FMP_API_KEY=

# Backtest date range (used by the backtest profile)
BT_START=2024-06-01
BT_END=2025-12-31
